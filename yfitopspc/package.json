{
  "name": "Yfitops-windows_",
  "version": "1.2.0",
  "description": "YFitops Desktop",
  "author": "Rexy_130",
  "homepage": "https://yfitops.duckdns.org",
  "main": "main.js",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "watch": "concurrently \"webpack --watch --mode development\" \"electron .\"",
    "build": "webpack --mode production",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "dist:all": "npm run build && electron-builder --win --linux --x64"
  },
  "build": {
    "appId": "com.yfitops.pc",
    "productName": "YFitops",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YFitops"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Audio",
      "executableName": "yfitops",
      "maintainer": "YFitops"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "discordRpc.js",
      "localData.js",
      "autostart.js",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}